{
  "manifest_version": 3,
  "name": "ContextLens",
  "version": "1.0.0",
  "description": "Instant, context-aware AI explanations for any highlighted text on the web.",
  "author": "ContextLens",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ContextLens – History Vault"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ]
}
